# shopsystem-product lead-shop environment — COPY to .env and fill in.
#
# .env is gitignored and must NEVER be committed. It holds the agent-vault
# broker master password, which auto-unlocks the encrypted vault on restart
# (ADR-028 D1 / PDR-017 SB-7) so a broker restart needs no human re-paste.
#
# Generate a strong value once, e.g.:  openssl rand -base64 32
AGENT_VAULT_MASTER_PASSWORD=

# Optional. External base URL the broker advertises in invites/links. Defaults
# to http://agent-vault:14321 (the shopsystem-network alias BCs reach it by).
# AGENT_VAULT_ADDR=http://agent-vault:14321

# Optional. Where persistent supporting-service state lives (pgdata + the
# agent-vault vault). Defaults to $HOME/.local/share/shopsystem.
# SHOPSYSTEM_DATA=
