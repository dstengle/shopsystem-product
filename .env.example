# shopsystem-product lead-shop environment — COPY to .env and fill in.
#
# .env is gitignored and must NEVER be committed. It holds the agent-vault
# broker master password, which auto-unlocks the encrypted vault on restart
# (ADR-028 D1 / PDR-017 SB-7) so a broker restart needs no human re-paste.
#
# Generate a strong value once, e.g.:  openssl rand -base64 32
AGENT_VAULT_MASTER_PASSWORD=

# Optional. Password for the messaging postgres supporting service. The compose
# default ("postgres") works out-of-the-box for local dev — leave this unset to
# keep that. CHANGE FOR ANY NON-LOCAL DEPLOYMENT: set a strong value here and the
# postgres service will read it.
# POSTGRES_PASSWORD=postgres

# Optional. External base URL the broker advertises in invites/links. Defaults
# to http://agent-vault:14321 (the shopsystem-network alias BCs reach it by).
# AGENT_VAULT_ADDR=http://agent-vault:14321

# Optional but RECOMMENDED. The broker proxy token (av_agt_...) bin/shop-shell
# injects so the shell container reaches Claude + github.com through the broker
# with NO host ~/.claude / ~/.gitconfig mounts (ADR-028, 2026-06-12). Record the
# value bin/agent-vault-provision prints at step 5 ("RECORD the av_agt_... token").
# If left unset, shop-shell recovers it from a running BC container's env; if no
# BC is running and this is unset, shop-shell errors out (no host-cred fallback).
# The token is non-expiring; rotate/revoke via `agent-vault agent rotate`.
# AGENT_VAULT_TOKEN=av_agt_...

# Optional. The broker vault name (defaults to "fleet"). Only set if you
# provisioned a non-default vault.
# AGENT_VAULT_VAULT=fleet

# Optional. Where persistent supporting-service state lives (pgdata + the
# agent-vault vault). Defaults to $HOME/.local/share/shopsystem.
# SHOPSYSTEM_DATA=
