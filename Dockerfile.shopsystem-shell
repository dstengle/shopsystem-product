# shopsystem-shell — prototype daily-driver shell image.
#
# Rebased onto the devcontainer image we already run BCs and the lead host in.
# That base ships, out of the box:
#   - claude (the CLI) on PATH                       <- was missing before
#   - docker CLI + Microsoft's docker-init.sh entrypoint, which reconciles the
#     mounted socket's GID so the non-root vscode user can reach the daemon
#   - bd, tmux, node, python, git, pipx, the vscode (uid 1000) user
# so this file only has to add the framework CLIs that aren't baked into the
# base. Canonical form will be rendered by `shopsystem-templates init` /
# published by shopsystem-bc-launcher once those scenarios land.
#
# Build with:
#   docker build -t shopsystem-shell:dev -f Dockerfile.shopsystem-shell .

FROM ghcr.io/dstengle/shopsystem-bc-base:latest

USER vscode

# Framework CLIs, pinned to match this repo's pyproject.toml so `shop-msg`,
# `scenarios`, `shop-templates` resolve to the same revisions the lead installs.
# pipx matches the base image's convention (everything lands on ~/.local/bin).
# --force re-pins shop-templates even though the base image already ships it.
#
# bc-launcher is INTENTIONALLY OMITTED — dstengle/shopsystem-bc-launcher is a
# private repo and git clone needs credentials this image can't carry. Install
# it at runtime from inside the shell once your gh credentials are available:
#   pipx install "bc-launcher @ git+https://github.com/dstengle/shopsystem-bc-launcher@caf62f5"
# (Or make the repo public and add it to this layer.)
RUN pipx install --force \
        "scenarios @ git+https://github.com/dstengle/shopsystem-scenarios@v0.1.0" \
 && pipx install --force \
        "shop-templates @ git+https://github.com/dstengle/shopsystem-templates@d1a8937" \
 && pipx install --force \
        "shopsystem-messaging @ git+https://github.com/dstengle/shopsystem-messaging@1514e8a"

WORKDIR /workspace
CMD ["/bin/bash"]
