#!/usr/bin/env bash
# agent-vault-provision — the ONE human-gated credential paste (ADR-026 D4 /
# PDR-017 SB-6), run ONCE to provision the broker vault for the fleet.
#
# Everything else about the broker is automated (compose brings it up,
# .env auto-unlocks it on restart). This is the single out-of-band step:
# a human reads the real Claude OAuth + GitHub credentials and stores them in
# the broker vault. No other part of fleet bring-up or BC launch reads, writes,
# or transports a real credential.
#
# Run from the lead host after the broker is up:
#   cp .env.example .env && edit .env   # set AGENT_VAULT_MASTER_PASSWORD
#   bin/shop-shell                      # (or: docker compose up -d agent-vault)
#   bin/agent-vault-provision
#
# The agent-vault CLI is invoked INSIDE the running broker container, so no host
# install is needed. Commands follow agent-vault v0.7.0; if a flag is rejected,
# confirm against `docker exec shopsystem-agent-vault-1 agent-vault <cmd> --help`
# (this script prints what it is about to run and stops on error).
#
# NOTE — Claude Code uses an OAuth Bearer flow, NOT the api-key `anthropic`
# catalog template (spike lead-jkwo, finding 4). The three Bearer hosts below
# must be configured as custom bearer services that reference token-key
# CLAUDE_OAUTH.
#
# CRITICAL — the Claude credential is the REFRESHING OAuth credential TYPE, which
# is NOT scriptable in agent-vault 0.32.0 (verified live 2026-06-10, lead-5jbc):
# `credential set` and `proposal create --credential` are flat KEY=value /
# KEY=description only — no Token-URL / Client-ID / refresh-token / auth-method
# fields. The OAuth credential TYPE is created in the DASHBOARD Credentials tab
# (:14321 on the docker host). The refresh behavior lives in the CREDENTIAL
# object, not the service, so the services below stay fully scriptable; only the
# Claude credential itself stops for a human dashboard step (step 4b). The old
# static `CLAUDE_CODE_OAUTH_TOKEN` path expired the lead's creds — do NOT use it.
# ADR-026 D2 (resolved 2026-06-10) records the live proof.

set -euo pipefail

CONTAINER="shopsystem-agent-vault-1"
VAULT="${AGENT_VAULT_VAULT:-fleet}"
AGENT="${AGENT_VAULT_AGENT:-bc-fleet}"

av() { docker exec -i "$CONTAINER" agent-vault "$@"; }

prompt_secret() {  # $1 = human label; echoes the pasted value
    local v
    read -r -s -p "  paste $1 (input hidden), then Enter: " v >&2
    echo >&2
    printf '%s' "$v"
}

if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    echo "ERROR: broker container '$CONTAINER' is not running. Bring it up first:" >&2
    echo "  cp .env.example .env  # set AGENT_VAULT_MASTER_PASSWORD, then:" >&2
    echo "  docker compose --env-file .env up -d agent-vault" >&2
    exit 1
fi

echo "== agent-vault provisioning (one-time) =="
echo "broker: $CONTAINER   vault: $VAULT   agent: $AGENT"
echo

# 1) Owner account (first registered user becomes owner). Idempotent-guarded:
#    skip if registration fails because an owner already exists.
echo "-- step 1: owner account --"
read -r -p "  owner email: " OWNER_EMAIL
echo "  (choose an owner password; stored only in the vault DB)"
OWNER_PW="$(prompt_secret 'owner password')"
if printf '%s' "$OWNER_PW" | av auth register --email "$OWNER_EMAIL" --password-stdin; then
    echo "  owner registered."
else
    echo "  auth register returned non-zero — assuming owner already exists; continuing."
fi

# 2) Vault
echo "-- step 2: vault '$VAULT' --"
av vault create "$VAULT" || echo "  vault create returned non-zero — assuming it exists; continuing."

# 3) Services (proxy substitution rules). ALL vault subcommands MUST pass
#    --vault "$VAULT": in agent mode there is no interactive vault picker, and
#    under `docker exec -i` (no TTY) an omitted --vault fails. Do NOT swallow
#    these failures — a silently-empty service list makes the broker 405 every
#    request (the failure mode the canary caught).
echo "-- step 3: services --"
# GitHub git-over-https (clone/push to github.com) — Basic auth (username + PAT).
# NOTE: git hits github.com, NOT api.github.com; a Bearer-on-api.github.com
# service alone does NOT broker git operations.
av vault service add --vault "$VAULT" --name github-git --host github.com \
    --auth-type basic --username-key GITHUB_USERNAME --password-key GITHUB_TOKEN
# GitHub API (gh CLI) — Bearer to api.github.com.
av vault service add --vault "$VAULT" --name github-api --host api.github.com \
    --auth-type bearer --token-key GITHUB_TOKEN
# Claude Code OAuth Bearer hosts (the built-in 'anthropic' catalog template is
# x-api-key, NOT the OAuth Bearer flow Claude Code uses — configure manually).
# These services reference token-key CLAUDE_OAUTH, the refreshing OAuth
# credential created in the dashboard at step 4b. The service is scriptable; the
# credential is not (see header NOTE). Refresh is handled natively by the broker
# (ADR-026 D2, resolved 2026-06-10) — no re-paste needed once the OAuth
# credential is in place.
for host in api.anthropic.com platform.claude.com mcp-proxy.anthropic.com; do
    av vault service add --vault "$VAULT" --name "claude-${host%%.*}" --host "$host" \
        --auth-type bearer --token-key CLAUDE_OAUTH
done
echo "  services:"; av vault service list --vault "$VAULT" 2>&1 | grep -E 'name:|host:' | sed 's/^/    /'

# 4a) GITHUB CREDENTIALS — scriptable (flat key=value), the human-gated paste.
#     The GitHub leg is a static Basic-PAT credential; the flat CLI expresses it.
echo "-- step 4a: load real GitHub credentials (human-gated paste) --"
read -r -p "  GitHub username (or x-access-token): " GH_USER
echo "  GitHub: a PAT with repo push scope (durable — a short-lived 'gh auth token' will expire)."
GH_TOKEN="$(prompt_secret 'GitHub PAT')"
# credential set takes key=value args + --vault (no documented stdin form).
av vault credential set --vault "$VAULT" \
    "GITHUB_USERNAME=$GH_USER" "GITHUB_TOKEN=$GH_TOKEN"
unset GH_TOKEN GH_USER OWNER_PW
echo "  GitHub credentials stored in vault $VAULT."

# 4b) CLAUDE OAUTH CREDENTIAL — NOT scriptable; STOP for a human dashboard step.
#     agent-vault 0.32.0 has NO CLI/API path to create the refreshing OAuth
#     credential TYPE (verified live 2026-06-10, lead-5jbc). The flat
#     `credential set CLAUDE_OAUTH=<accessToken>` would store the STATIC type,
#     which expires (the canary's failure mode). Create the OAuth credential in
#     the dashboard so the broker can auto-refresh it.
echo "-- step 4b: Claude OAuth credential (MANUAL — dashboard only) --"
cat >&2 <<EOF

  >>> STOP. The Claude credential CANNOT be created from this script.
      agent-vault 0.32.0 has no CLI/API path for the refreshing OAuth
      credential type (flat 'credential set' would store a STATIC token
      that expires — the canary's failure mode).

  Create it ONCE in the agent-vault DASHBOARD (Credentials tab):
      URL:          http://<docker-host>:14321  (log in as the owner)
      Vault:        $VAULT
      Key:          CLAUDE_OAUTH
      Type:         OAuth
      Token URL:    https://console.anthropic.com/v1/oauth/token
      Client ID:    9d1c250a-e61b-44d9-88ed-5944d1962f5e
      Auth Method:  None
      Access token: the "accessToken"  from ~/.claude/.credentials.json
      Refresh token:the "refreshToken" from ~/.claude/.credentials.json

  The broker then auto-refreshes the access token within 5 min of expiry
  via the stored refresh token (ADR-026 D2, proven live 2026-06-10). The
  three claude-* services above already reference token-key CLAUDE_OAUTH.

EOF
read -r -p "  Press Enter once the CLAUDE_OAUTH credential exists in the dashboard... " _
# Verify the human actually created it before proceeding.
if av vault credential list --vault "$VAULT" 2>&1 | grep -q 'CLAUDE_OAUTH'; then
    echo "  CLAUDE_OAUTH present in vault $VAULT — continuing."
else
    echo "  ERROR: CLAUDE_OAUTH not found in vault $VAULT. Create it in the" >&2
    echo "         dashboard (see fields above) and re-run, or the brokered" >&2
    echo "         Claude leg will 405/401 on every request." >&2
    exit 1
fi

# 5) Agent + proxy token the BCs use. `agent create` PRINTS the proxy token
#    (av_agt_...) — THAT is the AGENT_VAULT_TOKEN bc-launcher injects; revocable,
#    grants only proxy substitution (ADR-026). RECORD the av_agt_ value it prints.
echo "-- step 5: fleet agent + proxy token --"
echo "  >>> RECORD the av_agt_... token printed below — it is AGENT_VAULT_TOKEN for launches:"
av agent create "$AGENT" --vault "$VAULT:proxy" \
    || echo "  agent create non-zero — agent likely exists; recover the token with: docker exec -i $CONTAINER agent-vault vault token --vault $VAULT --ttl 31536000"
# NOTE: `vault token` needs --vault (else it opens an interactive vault picker
# that fails under `docker exec -i` with no TTY). The agent token above is
# normally sufficient; this is only an alternative session token if you want one.

# 6) CA the BC containers must trust so the MITM proxy's TLS validates.
#    The vault state lives in the named volume; copy the CA out to a host file
#    that bc-launcher can mount into BC containers' trust store.
echo "-- step 6: fetch CA --"
CA_OUT="${AGENT_VAULT_CA_OUT:-$PWD/agent-vault-ca.pem}"
if av ca fetch -o /data/agent-vault-ca.pem \
   && docker cp "$CONTAINER:/data/agent-vault-ca.pem" "$CA_OUT"; then
    echo "  CA written to $CA_OUT (mount this into BC containers)."
else
    echo "  ca fetch/cp non-zero — fetch manually:" >&2
    echo "    docker exec $CONTAINER agent-vault ca fetch -o /data/agent-vault-ca.pem" >&2
    echo "    docker cp $CONTAINER:/data/agent-vault-ca.pem ./agent-vault-ca.pem" >&2
fi

echo
echo "== done =="
echo "Fleet launch config (bc-launcher) must point at:"
echo "  AGENT_VAULT_ADDR=http://agent-vault:14321"
echo "  AGENT_VAULT_VAULT=$VAULT"
echo "  AGENT_VAULT_TOKEN=<the token minted in step 5>"
echo "  + mount the CA from step 6 into the BC container's trust store."
