#!/usr/bin/env bash
# shop-shell — one-entrypoint shell for working on this shop.
#
# Brings up BOTH lead-shop supporting services (postgres for shop-msg + the
# agent-vault credential broker, per ADR-028 D1) if not already running, then
# drops you into the shopsystem-shell container with /workspace bind-mounted to
# the repo root. Host requirement: docker only.
#
# The agent-vault broker needs a master password in an UNCOMMITTED .env
# (see .env.example). Until that exists, the broker is skipped with a notice —
# postgres and the shell still come up. Provision the vault once with
# bin/agent-vault-provision (the one human-gated credential paste, ADR-026 D4).
#
# Override the shell image with SHOPSYSTEM_SHELL_IMAGE; defaults to the local
# prototype tag, which you build with:
#   docker build -t shopsystem-shell:dev -f Dockerfile.shopsystem-shell .

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA="${SHOPSYSTEM_DATA:-$HOME/.local/share/shopsystem}"
IMAGE="${SHOPSYSTEM_SHELL_IMAGE:-shopsystem-shell:dev}"
IMAGE="ghcr.io/dstengle/shopsystem-bc-base:latest"

mkdir -p "$DATA/pgdata"  # broker vault uses a named volume, not a host dir

# compose reads the broker master password from $ROOT/.env. Pass it explicitly
# so bring-up is deterministic regardless of the caller's CWD.
COMPOSE=(docker compose -f "$ROOT/compose.yaml")
[ -f "$ROOT/.env" ] && COMPOSE+=(--env-file "$ROOT/.env")

# Bring up the supporting services if they aren't already (ADR-028 D1: one
# entrypoint stands up the coherent two-server fleet).
if ! docker ps --format '{{.Names}}' | grep -qx shopsystem-messaging-postgres-1; then
    "${COMPOSE[@]}" up -d postgres
fi
if ! docker ps --format '{{.Names}}' | grep -qx shopsystem-agent-vault-1; then
    if [ -f "$ROOT/.env" ] && grep -q '^AGENT_VAULT_MASTER_PASSWORD=' "$ROOT/.env"; then
        "${COMPOSE[@]}" up -d agent-vault
    else
        echo "shop-shell: agent-vault broker NOT started — no AGENT_VAULT_MASTER_PASSWORD in $ROOT/.env" >&2
        echo "            copy .env.example to .env, set the password, then run bin/agent-vault-provision once." >&2
    fi
fi

# The mounted docker socket is mode 660 (root:docker on the host). The shell
# runs as the non-root vscode user, so it must join the socket's group to use
# it — otherwise every docker call inside the shell is permission-denied.
# --group-add takes the numeric GID directly, so this works whether the socket
# is group-docker or group-root. (stat -L follows the /var/run/docker.sock
# symlink the devcontainer feature installs.)
SOCKET_GID="$(stat -L -c '%g' /var/run/docker.sock)"

# Hand off to the shell container. Run as the non-root vscode user (uid 1000,
# provisioned in bc-base with HOME=/home/vscode — the home the .claude/.gitconfig
# mounts below target). The image's default USER is root, and Claude Code refuses
# --dangerously-skip-permissions when EUID==0, so without this --user the shell
# drops into root and `claude` won't start. This mirrors how the launcher runs
# the BC agent: `docker exec --user vscode` (controller.AGENT_CONTAINER_USER).
# Named `vscode` (not numeric $(id -u):$(id -g)) so $HOME and a passwd entry
# resolve — host and image vscode are both 1000:1000, so they coincide anyway.
exec docker run --rm -it \
    --network shopsystem \
    --user vscode \
    --group-add "$SOCKET_GID" \
    --workdir /workspace \
    -v "$ROOT:/workspace" \
    -v /var/run/docker.sock:/var/run/docker.sock \
    -v "$HOME/.claude:/home/vscode/.claude" \
    -v "$HOME/.gitconfig:/home/vscode/.gitconfig:ro" \
    -e SHOPMSG_DSN="postgresql://postgres:postgres@shopsystem-messaging-postgres-1:5432/shopsystem" \
    "$IMAGE" \
    bash
