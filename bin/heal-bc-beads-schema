#!/usr/bin/env bash
# bin/heal-bc-beads-schema — agent-free heal for the bd remote-backed schema
# wall. RUNS INSIDE A BC CONTAINER. Idempotent. BC-only (refuses lead beads).
#
# Context (lead-4qqi, lead-065a, lead-yy1q; bd upstream #4259):
#   * bc-base bakes a bd whose target schema (e.g. v53) is ahead of a BC's
#     remote-backed beads DB (e.g. v32).
#   * bd REFUSES to auto-apply schema migrations to a remote-backed DB because
#     migrating independently on >1 clone forks the schema (`bd dolt pull` can
#     no longer merge). So `bd bootstrap` at BC standup fails -> BC never onlines.
#   * migrate-in-place is ALSO unreliable across BCs: on knowledge-beads
#     `BD_ALLOW_REMOTE_MIGRATE=1 bd migrate` HARD-FAILS at migration 0047
#     (Error 1146: table not found: wisps) even though the SAME bd (1.1.0)
#     migrated the lead cleanly (lead-065a) — nominally-"v32" BC DBs have
#     divergent actual schemas, so the migration chain's table prerequisites
#     are not met everywhere.
#
# THEREFORE this heal does NOT migrate-in-place. It REBUILDS the local DB fresh
# at the CURRENT schema from the schema-independent committed .beads/issues.jsonl
# (`bd init --from-jsonl`), which always yields a working current-schema DB and
# onlines the BC. SAFE for a BC: the container is the sole clone of its beads
# remote and the committed JSONL is the source of truth. (The LEAD is NOT
# sole-clone and migrate-in-place preserves its Dolt history there, so this
# script refuses a lead-role beads unless HEAL_ALLOW_LEAD=1.)
#
# After the local rebuild (which onlines the BC) it attempts a best-effort remote
# reseed force-push so future launches adopt the current schema. That push may
# fail in-container on the dolt MITM-CA / non-interactive-credential gap
# (create-bc seed GAP family, lead-tc38/lead-vb6j) — that is non-fatal: the BC is
# already online locally and the push can be retried once creds are wired.
set -uo pipefail

WORKDIR="${BD_WORKDIR:-/workspace}"
cd "$WORKDIR" 2>/dev/null || { echo "[heal-beads] cannot cd $WORKDIR" >&2; exit 2; }
BEADS_DIR="$WORKDIR/.beads"
FORCE_LEAD="${HEAL_ALLOW_LEAD:-0}"

log() { printf '[heal-beads] %s\n' "$*"; }
die() { log "ERROR: $*"; exit 1; }
filt() { grep -viE 'permissions 0755|chmod 700' || true; }

command -v bd >/dev/null 2>&1 || die "bd not on PATH"
[ -d "$BEADS_DIR" ] || die "no .beads dir at $BEADS_DIR (BC not provisioned?)"

# --- Guard: refuse to auto-reseed a LEAD-role beads (not sole-clone) ---
shop_type="$(tr -d '[:space:]' < "$WORKDIR/.claude/shop/type.md" 2>/dev/null || true)"
if [ "$shop_type" = "lead" ] && [ "$FORCE_LEAD" != "1" ]; then
  die "shop type is 'lead' — a reseed force-push would discard lead Dolt history and the lead is not guaranteed sole-clone. Heal the lead by hand (BD_ALLOW_REMOTE_MIGRATE=1 bd migrate + bd dolt push) as the sole designated migrator."
fi

# --- 1. Already healthy? ---
if bd ready >/dev/null 2>&1; then
  log "bd ready already works — no heal needed. Nothing to do."
  exit 0
fi
insp="$(bd migrate --inspect 2>&1 || true)"
if ! printf '%s\n' "$insp" | grep -qiE 'schema migration|migrations \(v|will not (auto-)?apply|remote-backed'; then
  log "bd ready fails but no schema-skew signal detected. Diagnostics:"
  printf '%s\n' "$insp" | sed 's/^/[heal-beads]   /'
  die "refusing to reseed without a clear schema-skew signal; manual inspection needed."
fi
log "schema skew detected (remote-backed DB behind bd's target schema)."

# --- 2. Derive issue prefix (needed for a fresh init) ---
JSONL="$BEADS_DIR/issues.jsonl"
[ -s "$JSONL" ] || die "no committed issues.jsonl to rebuild from ($JSONL missing/empty)."
PREFIX="$(grep -oE '"id":"[^"]+"' "$JSONL" | head -1 | sed -E 's/.*"id":"//; s/-[^-]*"$//')"
if [ -z "$PREFIX" ]; then
  PREFIX="$(grep -oE '"dolt_database"[[:space:]]*:[[:space:]]*"[^"]+"' "$BEADS_DIR/metadata.json" 2>/dev/null | sed -E 's/.*"([^"]+)"$/\1/')"
fi
[ -n "$PREFIX" ] || die "could not derive issue prefix from issues.jsonl or metadata.json."
NI="$(grep -c '"_type":"issue"' "$JSONL" 2>/dev/null || echo '?')"
log "rebuild target: prefix=$PREFIX, committed issues=$NI"

# --- 3. Safety net: full export before any destructive step (read-only) ---
mkdir -p "$BEADS_DIR/backup"
bd export --all -o "$BEADS_DIR/backup/pre-heal-capture.jsonl" >/dev/null 2>&1 \
  && log "safety export OK -> .beads/backup/pre-heal-capture.jsonl" \
  || log "WARNING: pre-heal export failed (DB may be unreadable); committed issues.jsonl remains the source of truth."

# --- 4. Local reseed from JSONL at current schema (proven; onlines the BC) ---
# Temporarily unconfigure sync.remote so the fresh init is purely local (no
# remote clone/refuse). Config is restored on ANY exit via the trap.
CFG="$BEADS_DIR/config.yaml"
CFG_BAK="$BEADS_DIR/config.yaml.heal-bak"
restore_cfg() { [ -f "$CFG_BAK" ] && mv -f "$CFG_BAK" "$CFG" 2>/dev/null || true; }
trap restore_cfg EXIT
cp -f "$CFG" "$CFG_BAK"
grep -v 'sync.remote' "$CFG_BAK" > "$CFG"

# Move the broken v32 clone aside (kept as .heal-bak for forensics).
[ -d "$BEADS_DIR/embeddeddolt" ] && rm -rf "$BEADS_DIR/embeddeddolt.heal-bak" 2>/dev/null \
  && mv "$BEADS_DIR/embeddeddolt" "$BEADS_DIR/embeddeddolt.heal-bak" 2>/dev/null || true

log "bd init --from-jsonl --reinit-local -p $PREFIX (fresh current-schema DB) ..."
BD_NON_INTERACTIVE=1 bd init --from-jsonl --reinit-local -p "$PREFIX" \
    --destroy-token "DESTROY-$PREFIX" 2>&1 | filt | tail -6

restore_cfg; trap - EXIT   # sync.remote restored; done with the local phase

if ! bd ready >/dev/null 2>&1; then
  die "reseed produced a DB but bd ready still fails; manual inspection needed."
fi
ver="$(bd migrate --inspect 2>/dev/null | grep -iE 'schema version' | grep -oE '[0-9.]+' | head -1)"
cnt="$(bd stats 2>/dev/null | grep -iE 'total issues' | grep -oE '[0-9]+' | head -1)"
log "LOCAL HEAL OK — bd ready works; schema=$ver issues=$cnt. BC can now online."

# --- 5. Best-effort remote reseed (force-push) so future launches adopt v-current ---
log "attempting remote reseed force-push (best-effort) ..."
if BD_NON_INTERACTIVE=1 bd init --reinit-local --discard-remote \
      --destroy-token "DESTROY-$PREFIX" >/dev/null 2>&1 && bd dolt push >/dev/null 2>&1; then
  log "REMOTE RESEED OK — remote now serves the current schema; future launches adopt cleanly."
else
  log "NOTE: remote reseed-push did not complete (likely the in-container dolt"
  log "      MITM-CA / non-interactive-credential gap — create-bc seed GAP family,"
  log "      lead-tc38/lead-vb6j). The BC is ONLINE locally; the remote is still"
  log "      behind, so a future re-launch will need this heal again until the"
  log "      remote is reseeded. Re-run 'bd dolt push' once dolt creds are wired."
fi
exit 0
