#!/usr/bin/env python3
"""gen-scenario-refs — regenerate the lead-side scenario-validation reference
indices (epic lead-vzxd, ADR-056 D10; findings/scenario-integrity/02).

The `scenarios validate` schema check enforces two membership sets that do NOT
live in a BC repo (ADR-018): the legal `@bc`/`@service` owner set and the legal
`@origin` provenance set. The lead OWNS the authoritative source of both and
publishes them as committed, reproducible reference artifacts the bc-launcher
provisions into each BC container at launch (findings/01 option (c)).

This generator is the reproducible producer for the `@origin` index. It does
NOT emit a `@bc`/`@service` projection: per the finalized format
(findings/02 decision 1a) the validator is HARDENED to read the real structured
`bc-manifest.yaml` directly, so that curated file IS the single-source-of-truth
`@bc`/`@service` reference — projecting it here would re-introduce drift. This
script instead ECHOES the manifest-derived legal `@bc`/`@service` set for audit
and emits the generated `@origin` index.

Outputs (relative to repo root):
  scenario-refs/origin-index.txt   — one legal @origin identifier per line

@origin identifiers emitted:
  adr-NNN     for each adr/NNN-*.md
  pdr-NNN     for each pdr/NNN-*.md
  brief-NNN   and brief-<slug>  for each briefs/NNN-*.md
              (both numeric and slug forms; ADR-056 D2 cites `brief-<slug>`,
               the numeric form mirrors adr-/pdr- — membership accepts either)

Lead bead ids (lead-<id>, shopsystem-<id>) are NOT enumerated: they resolve
dynamically via the validator's existing prefix rule, so the index stays a pure
decision-record membership list.

Run from the repo root:  python3 bin/gen-scenario-refs
"""
from __future__ import annotations

import re
import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
OUT_DIR = REPO / "scenario-refs"
OUT_FILE = OUT_DIR / "origin-index.txt"

# NNN-slug.md decision-record filename.
_RECORD_RE = re.compile(r"^(?P<num>\d{3})-(?P<slug>.+)\.md$")


def _record_ids(root: Path, prefix: str, *, include_slug: bool) -> list[str]:
    ids: list[str] = []
    if not root.is_dir():
        return ids
    for path in sorted(root.glob("*.md")):
        m = _RECORD_RE.match(path.name)
        if not m:
            continue
        ids.append(f"{prefix}-{m['num']}")
        if include_slug:
            ids.append(f"{prefix}-{m['slug']}")
    return ids


def _manifest_names(manifest: Path) -> tuple[list[str], list[str]]:
    """Extract the legal @bc / @service names from the structured manifest.

    Mirrors the HARDENED validator name-extraction (findings/02 decision 1a):
    each bcs:/services: entry may be a bare string OR a dict carrying `name`
    (plus remote/role/status/deferred_to, which are ignored here).
    """
    import yaml  # local import: only needed for the audit echo

    data = yaml.safe_load(manifest.read_text(encoding="utf-8")) or {}

    def names(section: str) -> list[str]:
        out: list[str] = []
        for entry in data.get(section) or []:
            if isinstance(entry, str):
                out.append(entry)
            elif isinstance(entry, dict) and entry.get("name"):
                out.append(entry["name"])
        return out

    return names("bcs"), names("services")


def main() -> int:
    origin_ids: list[str] = []
    origin_ids += _record_ids(REPO / "adr", "adr", include_slug=False)
    origin_ids += _record_ids(REPO / "pdr", "pdr", include_slug=False)
    origin_ids += _record_ids(REPO / "briefs", "brief", include_slug=True)

    OUT_DIR.mkdir(exist_ok=True)
    header = [
        "# origin-index.txt — legal @origin provenance identifiers (ADR-056 D10).",
        "# GENERATED by bin/gen-scenario-refs — DO NOT EDIT BY HAND; regenerate.",
        "# Consumed as a set-membership list by `scenarios validate --origin-index`",
        "# (findings/scenario-integrity/02). Bodies are never shipped; existence in",
        "# this list is what E_UNKNOWN_ORIGIN checks. Lead bead ids (lead-*/shopsystem-*)",
        "# are NOT listed — they resolve via the validator's prefix rule.",
        "#",
        f"# adr: {len(list((REPO/'adr').glob('*.md')))}  pdr: {len(list((REPO/'pdr').glob('*.md')))}  briefs: {len(list((REPO/'briefs').glob('*.md')))}",
    ]
    body = "\n".join(header + [""] + origin_ids) + "\n"
    OUT_FILE.write_text(body, encoding="utf-8")

    # Audit echo of the manifest-derived @bc/@service legal set (NOT written —
    # bc-manifest.yaml is the single source; the hardened validator reads it).
    manifest = REPO / "bc-manifest.yaml"
    if manifest.exists():
        bcs, services = _manifest_names(manifest)
        print(f"[audit] legal @bc      ({len(bcs)}): {', '.join(bcs)}", file=sys.stderr)
        print(f"[audit] legal @service ({len(services)}): {', '.join(services)}", file=sys.stderr)
        print("[audit] @bc/@service source = bc-manifest.yaml (hardened validator reads it directly)", file=sys.stderr)

    print(f"wrote {OUT_FILE.relative_to(REPO)}  ({len(origin_ids)} origin ids)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
