#!/usr/bin/env bash
#
# bc-fabro-watch — agent-free external inbox watcher for a fabro-engaged BC.
#
# Replaces the ADR-058 in-fabro INFINITE `fabro run dispatcher.toml` (a cyclic
# poll->dispatch->wait->poll loop whose per-tick run-graph events accumulate
# UNBOUNDED in the fabro server heap — proven in lead-01jw: server RSS grew
# 18->28GiB during PURE IDLE polling, OOM-bound) with a tiny shell supervisor
# that fires ONE **finite** `fabro run workflow.fabro` child per inbound inbox
# message. Each child reaches a terminal (`done`/`halt`) and EXITS; its event
# state — which lives in a fabro SERVER heap — is reclaimed by giving the child
# its OWN ephemeral server and KILLING that server the instant the child
# terminates. Idle => zero fabro runs, zero fabro servers, zero accumulation.
#
# The only always-resident process is `shop-msg watch --bc <name>`, which holds
# NO run-graph (it emits a line ONLY on a real message, never per poll tick) and
# doubles as the bc_presence liveness HEARTBEAT (UPSERTs (bc_name, last_seen_at)
# every 30s from the same process that holds the postgres LISTEN connection —
# this is the exact lead-8hpz fix: bc-status classifies online<90s).
#
# Runs INSIDE a bc-<name> container. Agent-free: no claude, no LLM, no Monitor.
# Constraints satisfied: C1 finite-run/bounded-memory, C2 agent-free,
# C3 heartbeat-via-watch, C4 in-flight dedup, C5 startup drain, C6 fault
# isolation + crash-trap pre-satisfaction. Honors ADR-050 D4/D6, ADR-051
# (child def UNCHANGED), ADR-058 G3/D5/AMENDMENT-2.

set -uo pipefail

# ---------------------------------------------------------------------------
# Configuration / defaults
# ---------------------------------------------------------------------------
# BC_NAME: positional arg > env > canonical shop marker (PDR-008 walk-up root).
BC_NAME="${1:-${BC_NAME:-}}"
if [ -z "${BC_NAME}" ] && [ -r /workspace/.claude/shop/name.md ]; then
    BC_NAME="$(tr -d '[:space:]' < /workspace/.claude/shop/name.md)"
fi
if [ -z "${BC_NAME}" ]; then
    echo "bc-fabro-watch: FATAL: BC_NAME not given (arg/env) and /workspace/.claude/shop/name.md unreadable" >&2
    exit 2
fi

# fabro def lives here; cwd MUST be the project dir or `fabro run` fails
# "workflow not found: /workspace/workflow.fabro" (crash-trap #1).
FABRO_DIR="${FABRO_DIR:-/workspace/.fabro}"

# Ephemeral per-run state (locks, sockets, per-run storage, child .toml copies).
STATE_DIR="${FABRO_WATCH_STATE:-/tmp/bc-fabro-watch}"
INFLIGHT_DIR="${STATE_DIR}/inflight"     # one lock subdir per live work_id (C4)
RUN_DIR="${STATE_DIR}/run"               # per-run sockets + storage
LOG="${FABRO_WATCH_LOG:-/dev/stderr}"

# Server config (~/.fabro/settings.toml) — distinct from project settings.
SERVER_CONFIG="${HOME}/.fabro/settings.toml"

# Poll-fallback cadence when `shop-msg watch` cannot stay up (seconds).
POLL_FALLBACK_SECS="${FABRO_WATCH_POLL_SECS:-10}"
# Bounded readiness wait for an ephemeral server socket (seconds).
SERVER_READY_TIMEOUT="${FABRO_WATCH_SERVER_TIMEOUT:-30}"

SHUTDOWN=0
WATCH_PID=""
WATCH_FIFO="${STATE_DIR}/watch.fifo"

# dev-token auth pair for ephemeral fabro servers. [server.auth] methods=
# ["dev-token"] requires a SESSION_SECRET server-side and a matching
# FABRO_DEV_TOKEN client-side; generated once, shared across ephemeral servers
# (one container = one trust domain).
WATCH_SESSION_SECRET=""
WATCH_DEV_TOKEN=""

log() { printf '%s bc-fabro-watch[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${BC_NAME}" "$*" >>"${LOG}" 2>/dev/null || true; }

# ---------------------------------------------------------------------------
# One-time setup
# ---------------------------------------------------------------------------
setup() {
    mkdir -p "${INFLIGHT_DIR}" "${RUN_DIR}" 2>/dev/null || true

    # Generate the dev-token auth pair once (see globals above).
    if [ -z "${WATCH_SESSION_SECRET}" ]; then
        WATCH_SESSION_SECRET="$(head -c32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
        WATCH_DEV_TOKEN="fabro_dev_$(head -c32 /dev/urandom | od -An -tx1 | tr -d ' \n')"
    fi

    if [ ! -d "${FABRO_DIR}" ]; then
        log "FATAL: fabro def dir ${FABRO_DIR} not present (BC not fabro-engaged / def not poured)"
        exit 3
    fi
    # cwd = project dir so `fabro run child-*.toml` resolves the poured
    # workflow.fabro sibling (crash-trap #1).
    cd "${FABRO_DIR}" || { log "FATAL: cannot cd ${FABRO_DIR}"; exit 3; }

    # Server auth config must exist (crash-trap #2): [server.auth] methods,
    # 64-hex SESSION_SECRET, fabro_dev_+64hex FABRO_DEV_TOKEN. Idempotent:
    # only provision if absent (this is exactly what the fabro engage runs).
    if [ ! -f "${SERVER_CONFIG}" ]; then
        log "provisioning fabro server config via 'fabro install' (absent: ${SERVER_CONFIG})"
        if ! fabro install --non-interactive --skip-llm --github-strategy token >>"${LOG}" 2>&1; then
            log "WARN: 'fabro install' returned nonzero; continuing (server may already be usable)"
        fi
    fi

    # (Re)create the watch FIFO used to pipe the stream into the main shell so
    # the read loop, traps and in-flight tracking all run in this process.
    rm -f "${WATCH_FIFO}" 2>/dev/null || true
    mkfifo "${WATCH_FIFO}" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Filename-safe token for a work_id (unix-socket paths are length-limited).
# ---------------------------------------------------------------------------
safe() { printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'; }

# ---------------------------------------------------------------------------
# Materialize the per-child fabro entrypoint — BYTE-FOR-BYTE the config that
# dispatch_acp_agent.py::materialize_child_config writes. WORK_ID/BC_NAME are
# delivered to the child's NATIVE script= nodes ONLY via [run.environment.env]
# ( `-I WORK_ID` does NOT reach them — proven, workflow.toml "Slice 5 finding").
# provider=local => in-process node execution, no docker daemon (crash-trap #3).
# graph=workflow.fabro => the UNCHANGED ADR-051 finite child (ADR-050 D6 parity).
# ---------------------------------------------------------------------------
materialize_child() {
    local wid="$1" path="$2"
    cat >"${path}" <<EOF
[workflow]
graph = "workflow.fabro"
[run.inputs]
BC_NAME = "${BC_NAME}"
WORK_ID = "${wid}"
[run.environment.env]
BC_NAME = "${BC_NAME}"
WORK_ID = "${wid}"
[run.environment]
id = "local"
[environments.local]
provider = "local"
[run.pull_request]
enabled = false
EOF
}

# ---------------------------------------------------------------------------
# run_finite <work_id>  — the per-message worker (runs BACKGROUNDED).
#
# Bounded-by-construction memory: the finite run's event history lives in a
# fabro SERVER heap, so we give THIS run its OWN ephemeral server (private unix
# socket + private storage-dir), run the child FOREGROUND (blocks to terminal),
# then KILL the server. Process termination — not in-server GC — is what frees
# the event state. When no message is in flight there is NO server and NO run.
# A failure anywhere here is logged and swallowed: it never reaches the watch
# reader loop (C6) and always releases the in-flight lock.
# ---------------------------------------------------------------------------
run_finite() {
    local wid="$1"
    local sw; sw="$(safe "${wid}")"
    local lock="${INFLIGHT_DIR}/${sw}"
    local sock="${RUN_DIR}/${sw}.sock"
    local store="${RUN_DIR}/${sw}.store"
    local child="${FABRO_DIR}/child-${sw}.toml"
    local srv_pid="" rc=0 waited=0

    cleanup_run() {
        [ -n "${srv_pid}" ] && kill "${srv_pid}" 2>/dev/null
        [ -n "${srv_pid}" ] && { wait "${srv_pid}" 2>/dev/null; }
        rm -f "${sock}" "${child}" 2>/dev/null || true
        rm -rf "${store}" 2>/dev/null || true
        rm -rf "${lock}" 2>/dev/null || true   # retire from in-flight set (C4)
    }
    trap 'cleanup_run' RETURN

    rm -f "${sock}" 2>/dev/null; rm -rf "${store}" 2>/dev/null
    mkdir -p "${store}" 2>/dev/null || true

    materialize_child "${wid}" "${child}" || { log "spawn ${wid}: materialize FAILED"; return 1; }

    # Ephemeral server bound to a private socket, isolated storage (C1), with the
    # generated dev-token auth pair (methods=["dev-token"] requires SESSION_SECRET).
    ( cd "${FABRO_DIR}" && SESSION_SECRET="${WATCH_SESSION_SECRET}" FABRO_DEV_TOKEN="${WATCH_DEV_TOKEN}" \
        exec fabro server start --foreground --no-web --quiet \
        --bind "${sock}" --storage-dir "${store}" ) >>"${LOG}" 2>&1 &
    srv_pid=$!

    # Bounded readiness wait for the socket (crash-trap: never block forever).
    while [ ! -S "${sock}" ]; do
        if ! kill -0 "${srv_pid}" 2>/dev/null; then
            log "spawn ${wid}: ephemeral server exited before ready; aborting run"
            return 1
        fi
        waited=$((waited + 1))
        if [ "${waited}" -ge $((SERVER_READY_TIMEOUT * 5)) ]; then
            log "spawn ${wid}: server socket not ready after ${SERVER_READY_TIMEOUT}s; aborting run"
            return 1
        fi
        sleep 0.2
    done
    sleep 0.3   # small settle after the socket appears

    log "spawn ${wid}: firing finite child (server pid ${srv_pid}, sock ${sock})"
    # FOREGROUND (no --detach): blocks until the run reaches done/halt, so the
    # server is killed (in cleanup_run) only AFTER the run has terminated —
    # never mid-flight. --auto-approve: no human gates in a headless watcher.
    SESSION_SECRET="${WATCH_SESSION_SECRET}" FABRO_DEV_TOKEN="${WATCH_DEV_TOKEN}" FABRO_SERVER="${sock}" \
        fabro run "child-${sw}.toml" --auto-approve >>"${LOG}" 2>&1
    rc=$?
    if [ "${rc}" -eq 0 ]; then
        log "child ${wid}: COMPLETE (rc=0)"
    else
        log "child ${wid}: run rc=${rc} (non-fatal; watcher continues)"
    fi
    return "${rc}"
}

# ---------------------------------------------------------------------------
# dispatch <work_id> — C4 dedup gate. Atomic `mkdir` lock: SPAWN exactly once
# per live work_id; SKIP if a child is already running for it. The lock is
# released by run_finite's cleanup on completion (retire), so a genuinely new
# message reusing the id dispatches again. Survives watch restarts because the
# lock dir persists across stream reconnects.
# ---------------------------------------------------------------------------
dispatch() {
    local wid="$1"
    [ -z "${wid}" ] && return 0
    [ "${SHUTDOWN}" -eq 1 ] && return 0
    local sw; sw="$(safe "${wid}")"
    if mkdir "${INFLIGHT_DIR}/${sw}" 2>/dev/null; then
        run_finite "${wid}" &          # detached worker; failures isolated (C6)
    else
        log "skip ${wid}: child already in flight (dedup)"
    fi
}

# ---------------------------------------------------------------------------
# drain — C5 startup / gap drain. Authoritative pending set is
# `shop-msg pending inbox --bc` (no-matching-outbox filter; idempotent — a
# work_id whose child already responded work_done is absent, so nothing
# re-fires). First whitespace field of each line is the work_id (same parse the
# dispatcher poll node feeds its ACP agent). ADR-058 G3: this query is the
# authority; the watch line is only the wake.
# ---------------------------------------------------------------------------
drain() {
    local out wid
    out="$(shop-msg pending inbox --bc "${BC_NAME}" 2>>"${LOG}")" || { log "drain: pending inbox query failed (transient)"; return 0; }
    [ -z "${out}" ] && return 0
    while IFS= read -r line; do
        wid="$(printf '%s' "${line}" | awk '{print $1}')"
        [ -n "${wid}" ] && dispatch "${wid}"
    done <<<"${out}"
}

# ---------------------------------------------------------------------------
# Shutdown seam (ADR-058 D7): stop accepting work, tear down the watch stream,
# and TERM any in-flight ephemeral servers so no orphaned fabro process leaks.
# In-flight children get a short grace, then are reaped.
# ---------------------------------------------------------------------------
shutdown() {
    [ "${SHUTDOWN}" -eq 1 ] && return
    SHUTDOWN=1
    log "shutdown signal received; stopping watch + reaping in-flight children"
    [ -n "${WATCH_PID}" ] && kill "${WATCH_PID}" 2>/dev/null
    # Grace for children to finish naturally.
    local grace=10
    while [ "${grace}" -gt 0 ] && [ -n "$(ls -A "${INFLIGHT_DIR}" 2>/dev/null)" ]; do
        sleep 1; grace=$((grace - 1))
    done
    # Reap anything still resident (kill our whole process group's children).
    pkill -TERM -P $$ 2>/dev/null || true
    rm -f "${WATCH_FIFO}" 2>/dev/null || true
    log "shutdown complete"
    exit 0
}
trap shutdown TERM INT

# ---------------------------------------------------------------------------
# poll_fallback — bounded ~POLL_FALLBACK_SECS sweep loop used ONLY while
# `shop-msg watch` is unavailable. Note: no shop-msg one-shot heartbeat exists,
# so bc_presence is NOT refreshed during fallback (watch is the sole heartbeat
# source) — presence may legitimately transition to stale, which is the honest
# signal that the event source is degraded. We attempt to restore watch on the
# NEXT supervise iteration; fallback runs for a bounded number of sweeps then
# yields back to a watch retry.
# ---------------------------------------------------------------------------
poll_fallback() {
    local sweeps="${1:-3}" i=0
    log "entering bounded poll-fallback (${POLL_FALLBACK_SECS}s cadence, ${sweeps} sweeps) — presence may go stale until watch restored"
    while [ "${i}" -lt "${sweeps}" ] && [ "${SHUTDOWN}" -eq 0 ]; do
        drain
        sleep "${POLL_FALLBACK_SECS}"
        i=$((i + 1))
    done
}

# ---------------------------------------------------------------------------
# watch_once — run one lifetime of `shop-msg watch --bc`. It drains pre-existing
# pending on connect (C5) then LISTENs, emitting one "<work_id> <message_type>"
# line per new message, AND heartbeats bc_presence every 30s (C3). We pipe it
# through a FIFO so the read loop executes in THIS shell (traps + in-flight
# state intact). Returns when the stream ends (watch exits only on DB-unreach).
# ---------------------------------------------------------------------------
watch_once() {
    local wid mtype
    # (Re)ensure the FIFO exists.
    [ -p "${WATCH_FIFO}" ] || mkfifo "${WATCH_FIFO}" 2>/dev/null || true

    shop-msg watch --bc "${BC_NAME}" >"${WATCH_FIFO}" 2>>"${LOG}" &
    WATCH_PID=$!
    log "shop-msg watch started (pid ${WATCH_PID}) — drain+LISTEN+heartbeat"

    # Reading the FIFO blocks until the writer (watch) closes it (EOF on exit).
    while IFS=' ' read -r wid mtype; do
        [ "${SHUTDOWN}" -eq 1 ] && break
        [ -z "${wid}" ] && continue
        # Skip control/sentinel lines: shop-msg watch emits a bare "READY" when
        # the LISTEN stream is armed; real events are "<work_id> <message_type>"
        # (two fields). A single-field or READY line is not a work_id.
        if [ "${wid}" = "READY" ] || [ -z "${mtype}" ]; then
            log "watch sentinel: ${wid} ${mtype:-} (ignored)"
            continue
        fi
        log "event: ${wid} ${mtype}"
        # ADR-058 G3: treat the line only as a WAKE; the pending-inbox query is
        # the authority. Dispatch this wid directly (it IS pending by definition
        # of the notify), dedup-guarded.
        dispatch "${wid}"
    done <"${WATCH_FIFO}"

    wait "${WATCH_PID}" 2>/dev/null
    local rc=$?
    WATCH_PID=""
    log "shop-msg watch stream ended (rc=${rc})"
    return "${rc}"
}

# ---------------------------------------------------------------------------
# supervise — keep `shop-msg watch` alive forever with bounded backoff. Between
# watch lifetimes, sweep pending inbox so nothing that arrived during the gap is
# missed. If watch cannot stay up, fall back to a bounded ~10s poll loop, then
# retry watch. A single `fabro run` failure NEVER reaches here (isolated in the
# backgrounded run_finite) — only a watch-stream exit does.
# ---------------------------------------------------------------------------
supervise() {
    local backoff=1 fails=0
    while [ "${SHUTDOWN}" -eq 0 ]; do
        watch_once
        [ "${SHUTDOWN}" -eq 1 ] && break

        # watch died — catch the gap immediately, then decide backoff/fallback.
        drain
        fails=$((fails + 1))
        if [ "${fails}" -ge 3 ]; then
            # Repeated flapping: degrade to bounded poll fallback, then reset.
            poll_fallback 3
            fails=0
            backoff=1
            continue
        fi
        log "watch down; backing off ${backoff}s before restart (consecutive fails=${fails})"
        sleep "${backoff}"
        backoff=$(( backoff * 2 )); [ "${backoff}" -gt "${POLL_FALLBACK_SECS}" ] && backoff="${POLL_FALLBACK_SECS}"
    done
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
main() {
    setup
    log "starting: BC_NAME=${BC_NAME} FABRO_DIR=${FABRO_DIR} STATE_DIR=${STATE_DIR}"
    drain          # C5 explicit startup drain (belt-and-suspenders with watch's own drain)
    supervise      # never returns except on shutdown
}

main "$@"
