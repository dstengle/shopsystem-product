
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Local sibling clones (BC repos cloned alongside the lead shop for
# convenience). Each is its own git repo with its own remote; they are
# not subdirectories of this repo.
/repos/

