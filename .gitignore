# commit. Template is .env.example.
.env

# agent-vault broker CA cert, fetched by bin/agent-vault-provision. Generated
# artifact (regenerable via `agent-vault ca fetch`); goes stale on re-provision.
agent-vault-ca.pem

# Python venv used for installing the framework CLIs into the lead shop.
.venv/

# pyproject build artifacts.
*.egg-info/
.specstory/history/2026-05-27_21-18-56Z-we-need-to-transition.md

# fabro e2e spike scratch — never commit (ADR-030 rejects committed scratch trees)
.fabro-e2e-scratch/
scratchpad/

# Local per-machine Claude Code overrides (not shared)
.claude/settings.local.json
